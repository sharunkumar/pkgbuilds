# Maintainer: Sharun Kumar <sharun@sharunkumar.com>
pkgname=watch-dogs-kde-splash-arch
pkgver=1.0
pkgrel=1
pkgdesc="Watch_Dogs x Arch Linux splash screen for KDE Plasma 6"
arch=(any)
url="https://github.com/sharunkumar/watch_dogs-kde-splash-arch"
license=(GPL)
depends=(plasma-workspace)
source=("git+https://github.com/sharunkumar/watch_dogs-kde-splash-arch.git")
sha256sums=('SKIP')

package() {
    cd watch_dogs-kde-splash-arch
    install -dm755 "$pkgdir/usr/share/plasma/look-and-feel/com.sharunkumar.watchdogsxarchlinux/contents"
    install -Dm644 metadata.json \
        "$pkgdir/usr/share/plasma/look-and-feel/com.sharunkumar.watchdogsxarchlinux/"
    cp -r contents/splash \
        "$pkgdir/usr/share/plasma/look-and-feel/com.sharunkumar.watchdogsxarchlinux/contents/"
}
