# Default terminal for xdg-terminal-exec.
#
# Selects Ghostty as the preferred terminal emulator for programs that
# launch a terminal via xdg-terminal-exec (e.g. desktop entries with
# Terminal=true launched via `gio launch`).
#
# Ghostty's official desktop entry sets `Exec=ghostty --gtk-single-instance=true`,
# so this routes any "open in terminal" request through the user's primary
# Ghostty instance instead of starting a new non-unique GApplication.
# Avoids duplicate XDG GlobalShortcuts portal registrations (and the
# resulting KDE shortcut-conflict popups) when Terminal=true desktop
# entries spawn while a primary Ghostty daemon is already running.
#
# Per-user overrides in ~/.config/xdg-terminals.list take precedence
# over this file.
com.mitchellh.ghostty.desktop
