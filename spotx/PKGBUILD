# Maintainer: Sharun Kumar <sharun@sharunkumar.com>

pkgname=spotx
pkgver=1
pkgrel=4
pkgdesc='Spotify pacman hook for SpotX'
arch=('any')
depends=('curl' 'bash' 'zip')
options=('!strip')

package() {
	install -dm755 "$pkgdir/etc/pacman.d/hooks/"
	install -m644 "$startdir/etc/pacman.d/hooks/spotify.hook" "$pkgdir/etc/pacman.d/hooks/spotify.hook"
}